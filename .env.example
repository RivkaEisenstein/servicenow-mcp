# ServiceNow Configuration
# SECURITY: Use environment variables, NEVER commit real credentials!
# IMPORTANT: Create a dedicated service account with LEAST PRIVILEGE roles
# DO NOT use 'admin' - use a service account with only required roles (e.g., itil, catalog)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=mcp_service_account
SERVICENOW_PASSWORD=your-password
SERVICENOW_AUTH_TYPE=basic

# Server Configuration
PORT=3000
DEBUG=false

# ============================================
# SECURITY CONFIGURATION
# ============================================

# API Key Authentication (REQUIRED - server will not start without this)
# Generate a secure key: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
MCP_API_KEY=your-secure-api-key-here

# Set to 'false' ONLY in isolated development environments
MCP_REQUIRE_API_KEY=true

# Network Binding (SECURITY)
# Default: 127.0.0.1 (localhost only - RECOMMENDED)
# Set to 0.0.0.0 ONLY if behind a reverse proxy with TLS
MCP_BIND_HOST=127.0.0.1

# Script Execution Control
# Set to 'false' to DISABLE background script execution entirely
# RECOMMENDED: Disable in production unless strictly required
ENABLE_SCRIPT_EXECUTION=false