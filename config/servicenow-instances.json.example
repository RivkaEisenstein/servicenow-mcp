{
  "_SECURITY_NOTICE": "NEVER commit real credentials! Use environment variable placeholders: ${VAR_NAME}",
  "instances": [
    {
      "name": "dev",
      "url": "${SERVICENOW_DEV_URL}",
      "username": "${SERVICENOW_DEV_USERNAME}",
      "password": "${SERVICENOW_DEV_PASSWORD}",
      "default": true,
      "description": "Development instance - use dedicated service account with least privilege"
    },
    {
      "name": "prod",
      "url": "${SERVICENOW_PROD_URL}",
      "username": "${SERVICENOW_PROD_USERNAME}",
      "password": "${SERVICENOW_PROD_PASSWORD}",
      "default": false,
      "description": "Production instance - use dedicated service account with least privilege"
    }
  ]
}